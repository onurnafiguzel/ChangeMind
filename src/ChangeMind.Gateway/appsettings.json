{
  "Urls": "http://localhost:5000",
  "Jwt": {
    "Secret": "your-super-secret-jwt-key-min-32-characters-long!",
    "Issuer": "ChangeMind",
    "Audience": "ChangeMindApi",
    "ExpirationMinutes": 60
  },
  "ReverseProxy": {
    "Routes": {
      "auth-login": {
        "ClusterId": "changemind-api",
        "RateLimiterPolicy": "strict",
        "Match": {
          "Path": "/api/auth/login",
          "Methods": ["POST"]
        }
      },
      "users-waiting": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "coach-or-admin",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/users/waiting",
          "Methods": ["GET"]
        }
      },
      "users-list": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "coach-or-admin",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/users",
          "Methods": ["GET"]
        }
      },
      "users-create": {
        "ClusterId": "changemind-api",
        "RateLimiterPolicy": "public",
        "Match": {
          "Path": "/api/users",
          "Methods": ["POST"]
        }
      },
      "users-complete-profile": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/users/{userId:guid}/complete-profile",
          "Methods": ["POST"]
        }
      },
      "users-change-password": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "strict",
        "Match": {
          "Path": "/api/users/{userId:guid}/change-password",
          "Methods": ["POST"]
        }
      },
      "users-by-id": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/users/{userId:guid}",
          "Methods": ["GET", "PUT", "DELETE"]
        }
      },
      "coaches-list": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "coach-or-admin",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/coaches",
          "Methods": ["GET"]
        }
      },
      "coaches-create": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "admin-only",
        "RateLimiterPolicy": "admin",
        "Match": {
          "Path": "/api/coaches",
          "Methods": ["POST"]
        }
      },
      "coaches-change-password": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "admin",
        "Match": {
          "Path": "/api/coaches/{coachId:guid}/change-password",
          "Methods": ["POST"]
        }
      },
      "coaches-by-id": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/coaches/{coachId:guid}",
          "Methods": ["GET", "PUT", "DELETE"]
        }
      },
      "packages-list": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/packages",
          "Methods": ["GET"]
        }
      },
      "packages-create": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "admin-only",
        "RateLimiterPolicy": "admin",
        "Match": {
          "Path": "/api/packages",
          "Methods": ["POST"]
        }
      },
      "packages-by-id": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "admin-only",
        "RateLimiterPolicy": "admin",
        "Match": {
          "Path": "/api/packages/{packageId:guid}",
          "Methods": ["GET", "PUT", "DELETE"]
        }
      },
      "payments": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/payments",
          "Methods": ["POST"]
        }
      },
      "training-programs-create": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "coach-only",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/training-programs",
          "Methods": ["POST"]
        }
      },
      "user-active-program": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/users/{userId:guid}/active-program",
          "Methods": ["GET"]
        }
      },
      "training-programs-by-id": {
        "ClusterId": "changemind-api",
        "AuthorizationPolicy": "auth",
        "RateLimiterPolicy": "standard",
        "Match": {
          "Path": "/api/training-programs/{programId:guid}",
          "Methods": ["GET"]
        }
      }
    },
    "Clusters": {
      "changemind-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5123"
          }
        }
      }
    }
  },
  "RateLimiting": {
    "Strict":   { "PermitLimit": 5,  "WindowSeconds": 60 },
    "Public":   { "PermitLimit": 20, "WindowSeconds": 60 },
    "Standard": { "PermitLimit": 60, "WindowSeconds": 60 },
    "Admin":    { "TokenLimit": 30, "ReplenishmentPeriodSeconds": 10, "TokensPerPeriod": 10 }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}
