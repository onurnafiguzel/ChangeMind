{
  "info": {
    "name": "ChangeMind User API",
    "description": "User CRUD API endpoints for ChangeMind",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:5123/api/users?isActiveOnly=true&page=1&pageSize=10",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5123",
              "path": [
                "api",
                "users"
              ],
              "query": [
                {
                  "key": "isActiveOnly",
                  "value": "true"
                },
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "pageSize",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "http://localhost:5123/api/users/{{userId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5123",
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"SecurePassword123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"age\": 28,\n  \"height\": 180.5,\n  \"weight\": 75.0,\n  \"gender\": \"male\",\n  \"fitnessGoal\": \"muscleGain\",\n  \"fitnessLevel\": \"intermediate\"\n}"
            },
            "url": {
              "raw": "http://localhost:5123/api/users",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5123",
              "path": [
                "api",
                "users"
              ]
            }
          }
        },
        {
          "name": "Update User",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"Johnny\",\n  \"lastName\": \"Doe\",\n  \"age\": 29,\n  \"height\": 181.0,\n  \"weight\": 76.0,\n  \"gender\": \"male\",\n  \"fitnessGoal\": \"strength\",\n  \"fitnessLevel\": \"advanced\"\n}"
            },
            "url": {
              "raw": "http://localhost:5123/api/users/{{userId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5123",
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Delete User (Soft Delete)",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "http://localhost:5123/api/users/{{userId}}",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5123",
              "path": [
                "api",
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"SecurePassword123!\",\n  \"newPassword\": \"NewSecurePassword456!\"\n}"
            },
            "url": {
              "raw": "http://localhost:5123/api/users/{{userId}}/change-password",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "5123",
              "path": [
                "api",
                "users",
                "{{userId}}",
                "change-password"
              ]
            }
          }
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "userId",
      "value": "your-user-id-here",
      "type": "string"
    }
  ]
}
