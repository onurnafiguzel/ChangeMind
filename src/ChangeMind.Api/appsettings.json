{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=changemind_db;Username=changemind;Password=changemind_pass;"
  },
  "Jwt": {
    "Secret": "this-is-a-super-secret-key-that-must-be-at-least-32-characters-long-change-in-production",
    "Issuer": "ChangeMindApi",
    "Audience": "ChangeMindApp",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Timeout": {
    "Database": {
      "CommandTimeoutSeconds": 5
    }
  },
  "Cache": {
    "ConnectionString": "localhost:6379,password=changemind_redis_pass",
    "DefaultTtlSeconds": 300,
    "InstanceName": "changemind:",
    "Resilience": {
      "RetryCount": 3,
      "RetryBaseDelayMs": 200,
      "CircuitBreakerFailureThreshold": 5,
      "CircuitBreakerBreakDurationSeconds": 30,
      "OperationTimeoutMs": 1000
    }
  },
  "Idempotency": {
    "LockTtlMs": 5000,
    "ResponseTtlHours": 24
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5000" ]
  }
}
