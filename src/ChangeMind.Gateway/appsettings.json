{
  "Urls": "http://localhost:5000",
  "ReverseProxy": {
    "Routes": {
      "api-route": {
        "ClusterId": "changemind-api",
        "Match": {
          "Path": "/api/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "changemind-api": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:5123"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}
